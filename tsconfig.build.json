{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "checkJs": false,
    "noEmit": false,
    "noCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "rewriteRelativeImportExtensions": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "src/types/**/*.d.ts"
  ]
}
