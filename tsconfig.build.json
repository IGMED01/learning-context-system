{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "checkJs": false,
    "noEmit": false,
    "noCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "rewriteRelativeImportExtensions": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": [
    "src/cli/arg-parser.js",
    "src/cli/teach-command.js",
    "src/contracts/config-contracts.js",
    "src/contracts/cli-contracts.js",
    "src/io/config-file.js",
    "src/io/text-file.js",
    "src/io/workspace-chunks.js",
    "src/memory/recall-queries.js",
    "src/security/secret-redaction.js",
    "src/system/project-ops.js"
  ]
}
