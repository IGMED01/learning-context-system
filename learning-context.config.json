{
  "schemaVersion": "1.0.0",
  "project": "learning-context-system",
  "workspace": ".",
  "output": {
    "jsonSchemaVersion": "1.0.0"
  },
  "selection": {
    "tokenBudget": 350,
    "maxChunks": 6,
    "minScore": 0.25,
    "sentenceBudget": 3
  },
  "memory": {
    "enabled": true,
    "project": "learning-context-system",
    "limit": 3,
    "scope": "project",
    "autoRecall": true,
    "autoRemember": false,
    "strictRecall": false,
    "degradedRecall": true
  },
  "engram": {
    "binaryPath": "tools/engram/engram.exe",
    "dataDir": ".engram"
  },
  "security": {
    "ignoreSensitiveFiles": true,
    "redactSensitiveContent": true,
    "ignoreGeneratedFiles": true,
    "allowSensitivePaths": [],
    "extraSensitivePathFragments": []
  },
  "scan": {
    "ignoreDirs": [".tmp", ".cache", "tmp", ".turbo", ".next", "out"]
  }
}
