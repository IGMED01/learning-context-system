{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "types": ["node"]
  },
  "include": [
    "src/contracts/config-contracts.js",
    "src/io/config-file.js",
    "src/io/workspace-chunks.js",
    "src/system/project-ops.js",
    "src/types/**/*.d.ts"
  ]
}
